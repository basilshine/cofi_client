## apps/web (workspace on use.ceits.app) local environment
## Copy to `.env.local` if you want to override defaults.

# Backend origin (no /api suffix). Requests use paths like /api/v1/...
# If omitted, same-origin + Vite proxy in dev (see apps/web/vite.config.ts → http://127.0.0.1:8090).
# VITE_API_URL=http://127.0.0.1:8090

# Marketing site (`ceits.app`). Used for “Ceits” links on login/register. Dev default: http://127.0.0.1:5173
# VITE_MARKETING_URL=https://ceits.app

# Public base URL of the Ceits workspace / Telegram web app. Used for “Open in Ceits app” links from Chat
# and the dashboard. In production set to `https://use.ceits.app` (same as this app). Omit to hide links.
# VITE_CEITS_APP_URL=https://use.ceits.app

